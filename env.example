# 511.org API — Register free at https://511.org/developers
API_KEY=your_api_key_here

# Feed configuration
FEED_AGENCY=SF
TARGET_ROUTES=14,38,49

# Collection (130s to stay within 60 req/hr limit)
POLL_INTERVAL_SECONDS=130

# Storage
DB_PATH=data/processed/transit.db
RAW_DIR=data/raw
STATIC_GTFS_PATH=data/static/sf_muni.zip

# Analysis Parameters
HEADWAY_WINDOW_MINUTES=30
BUNCHING_THRESHOLD_SECONDS=60
DELAY_THRESHOLD_SECONDS=300

# Logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
