@inproceedings{gongSDseq2seqDeepLearning2020,
  title = {{{SD-seq2seq}} : {{A Deep Learning Model}} for {{Bus Bunching Prediction Based}} on {{Smart Card Data}}},
  shorttitle = {{{SD-seq2seq}}},
  author = {Gong, Zengyang and Du, Bo and Liu, Zhidan and Zeng, Wei and Perez, Pascal and Wu, Kaishun},
  date = {2020-08-03},
  doi = {10.1109/ICCCN49398.2020.9209686},
  abstract = {Bus bunching, a phenomenon due to the failure of headway or timetable adherence, often causes low level of public transit service with poor bus on-time performance and excessive passenger waiting time. To mitigate bus bunching, an accurate and real-time prediction method plays an important role. In this paper, we propose a supply-demand seq2seq model called SD-seq2seq to predict bus bunching using smart card data. Features from both supply and demand sides of bus service are taken into account, like bus stop type, dwelling time, passenger demand and type, and so on. Extensive experiments on multiple bus routes in real world demonstrate that our method outperforms other baseline methods. The proposed method is expected to provide useful online information of bus operation to both bus operators and passengers.}
}

@inproceedings{junaedEVALUATINGIMPACTDEDICATED2022,
  title = {{{EVALUATING THE IMPACT OF DEDICATED BUS LANES ON TRAVEL TIME IN HETEROGENEOUS TRAFFIC CONDITION USING VISSIM}}},
  author = {Junaed, Siam and Sakib, Nazmus and Mamun, Md},
  date = {2022-12-22},
  abstract = {The traffic situation in Dhaka has deteriorated to the point that it has become intolerable. For a large number of people, traffic congestion consumes a significant amount of time. It is vital that a large number of people can travel to their destination in the shortest time. Making public transit (PT) more reliable and efficient is one of the solutions to this problem. Introducing dedicated lanes to prioritize PT can be an option to reduce the travel time of PT, allowing a large number of passengers to be traveled in a short period. However, deducting a lane will impair the travel time of other vehicles. The purpose of the study is to evaluate the impact of this modification on the travel time delay of vehicles on the network. For this purpose, a roadway corridor in Dhaka city is selected as the study area where a dedicated lane for PT is implemented without increasing the number of lanes. VISSIM, a microscopic simulation software, is used for the simulation and the effect of dedicated bus lanes on the change of travel time of vehicles is observed. The evaluation is done in terms of the change in overall vehicle travel time, passenger travel time, and average travel speed of vehicles at the selected corridor. It is observed that implementing a dedicated bus lane reduces the travel time of PT by 37.6 \% while increasing travel time for others.},
  file = {/home/war-machine/Zotero/storage/8GYSCH6J/Junaed et al. - 2022 - EVALUATING THE IMPACT OF DEDICATED BUS LANES ON TRAVEL TIME IN HETEROGENEOUS TRAFFIC CONDITION USING.pdf}
}

@article{juricPredictingPublicTransport2025,
