	\t\caption{Ablation Study: F1-Score by Sequential Window Depth}
	\t\centering
	\t\resizebox{\columnwidth}{!}{%
		\t\begin{tabular}{@{}lc@{}}
			\t\t\toprule
			\t\t\textbf{Window} & \textbf{F1-Score} \\ \midrule
			\t\t$n-1$           & 0.416             \\
			\t\t$n-2$           & 0.425             \\
			\t\t$n-3$           & 0.428             \\
